explicit temporal property [live]
  (forall T. 
    (globally eventually try_leave_cs(T))) -> 
  (forall T.    (globally ((T~=initial & entered(T)) -> eventually at(T))))
proof {
  tactic skolemizenp;
  tactic ranking with {

    # component 0: when some element after us is holding the token.
    definition work_created[0](U, V) = entered(U)&entered(V) 
    definition work_needed[0](U, V) = descendant(_T, U) & entered(U) & ( entered(V) & at(V) & descendant(_T, V) & (U = V | descendant(V, U)))
    definition work_invar[0] = entered(_T) & _T~=initial & ~at(_T)
    definition work_progress[0](U) = try_leave_cs(U) 
    definition work_helpful[0](U) = descendant(_T, U) & at(U) & entered(U) 

    # component 1: when some element before us is holding the token.
    definition work_created[2](U, V) = entered(U)&entered(V)
    definition work_needed[2](U, V) =  at(V) & V ~= _T & entered(V) & entered(U) & ~descendant(_T,V) & (U = _T | ((U = V | descendant(V,U)) & descendant(U,_T) ))
    definition work_invar[2] = entered(_T)  & _T~=initial & ~at(_T)
    definition work_progress[2](U) = try_leave_cs(U)
    definition work_helpful[2](U) = at(U) & U ~= _T & ~descendant(_T,U) & entered(U)

  }
#  showgoals
}


