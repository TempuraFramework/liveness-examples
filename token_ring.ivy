#lang ivy1.8

finite type proc 

# whether `proc` has entered the ring
relation entered(T:proc)

# whether `proc` holds the token in the ring
relation at(T:proc)

# transitive successor relation
relation descendant(T1:proc, T2:proc)

# successor relation
relation successor(T1:proc, T2:proc) = ~(exists V. descendant(T1,V)&descendant(V,T2))

# fairness condition
relation try_leave_cs(T:proc)

# initial ring element
var initial : proc

#############################################################
# ordering axioms
#############################################################

#axiom [successor_transitivity]
# ( successor(T1, T2) & successor(T2, T3) )  -> ( successor(T1, T3) )

#axiom [successor_antisymmetry]  ~successor(T,T) 

axiom [descendant_transitivity]
 ( descendant(T1, T2) & descendant(T2, T3) ) -> ( descendant(T1, T3) )

axiom [descendant_totality] T1~=T2 -> (descendant(T1,T2) | descendant(T2,T1))

#axiom [successor_uniqueness]
#  successor(T,U1) & successor(T,U2) -> U1 = U2

axiom [descendant_antisymmetry] ~descendant(T,T)

axiom [successor_descendant_compatible]
   successor(T1,T2) -> descendant(T1,T2)

axiom [descendant_least_element]
  T~=initial -> descendant(initial,T)

#axiom [successor_least_element]
#  ~successor(T, initial)

### XXX: need `complete=fo`
#axiom [descendant_unfold]
#  descendant(T,U) ->
#(    successor(T,U) |
#    (exists V. successor(T,V) & descendant(V,U)) )

after init {
  entered(T) := true;
  at(T) := false;
  try_leave_cs(T) := false;
  at(initial) := true;
}

action update_token(p:proc) = {
  require entered(p);

  try_leave_cs(p) := true;
  try_leave_cs(p) := false;

  if at(p) {
    if some n: proc. entered(n) & successor(p,n) { 
      # if p has a successor, pass token to successor.
      at(p) := false;
      at(n) := true;
    } else {
      # otherwise, p is the last node, so pass token to initial node. 
      at(p) := false;
      at(initial) := true;
    }
  }
}


export update_token


invariant [init0] entered(initial)
invariant [fair] ~try_leave_cs(T)
invariant [at0] exists T. at(T) 
invariant [at1] ~entered(T) -> ~at(T)
invariant [at2] at(T) -> entered(T)
invariant [at3] at(T1) & at(T2) -> T1 = T2

#### this passes
